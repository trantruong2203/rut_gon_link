msgid "Please find our advertising rate table below. Each visitor you will purchase will meet the following criteria:"
msgstr "Vui lòng xem bảng giá quảng cáo bên dưới. Mỗi lượt truy cập bạn mua sẽ đáp ứng các tiêu chí sau:"

msgid "Unique within a 24 hour time frame"
msgstr "Duy nhất trong khung thời gian 24 giờ"

msgid "They will have JavaScript enabled"
msgstr "Họ sẽ bật JavaScript"

msgid "They will have Cookies enabled"
msgstr "Họ sẽ bật Cookies"

msgid "Must view your website for at least {0} seconds"
msgstr "Phải xem website của bạn ít nhất {0} giây"

msgid "You may receive traffic that does not meet this criteria, but you will never be charged for it."
msgstr "Bạn có thể nhận traffic không đáp ứng tiêu chí này, nhưng bạn sẽ không bị tính phí."

msgid "I agree to the <a href=\"{0}\" target=\"_blank\">terms and conditions</a>"
msgstr "Tôi đồng ý với <a href=\"{0}\" target=\"_blank\">điều khoản và điều kiện</a>"

msgid "You have ordered {0} visitors for a total of {1}"
msgstr "Bạn đã đặt {0} lượt truy cập với tổng cộng {1}"

msgid "When your account reaches the minimum amount of {0} or more, you may request your earnings by clicking the above button. The payment is then sent to your PayPal account during business days no longer than 4 days after requesting. Please do not contact us regarding payments before due dates."
msgstr "Khi tài khoản đạt số tiền tối thiểu {0} trở lên, bạn có thể yêu cầu rút thu nhập bằng cách nhấn nút trên. Thanh toán sẽ được gửi đến tài khoản PayPal của bạn trong ngày làm việc, không quá 4 ngày sau khi yêu cầu. Vui lòng không liên hệ về thanh toán trước ngày đến hạn."

msgid "In order to receive your payments you need to fill your payment method and payment ID <a href=\"{0}\">here</a> if you haven't done so. You are also requested to fill all the required fields in the Account Details section with accurate data."
msgstr "Để nhận thanh toán, bạn cần điền phương thức thanh toán và ID thanh toán <a href=\"{0}\">tại đây</a> nếu chưa làm. Bạn cũng cần điền đầy đủ các trường bắt buộc trong phần Thông tin tài khoản với dữ liệu chính xác."

msgid "Pending: The payment is being checked by our team."
msgstr "Đang chờ: Thanh toán đang được đội ngũ kiểm tra."

msgid "Approved: The payment has been approved and is waiting to be sent."
msgstr "Đã duyệt: Thanh toán đã được phê duyệt và đang chờ gửi."

msgid "Complete: The payment has been successfully sent to your Paypal account."
msgstr "Hoàn tất: Thanh toán đã được gửi thành công đến tài khoản PayPal của bạn."

msgid "The {0} referral program is a great way to spread the word of this great service and to earn even more money with your short links! Refer friends and receive {1}% of their earnings for life!"
msgstr "Chương trình giới thiệu {0} là cách tuyệt vời để lan truyền dịch vụ và kiếm thêm thu nhập từ link rút gọn! Giới thiệu bạn bè và nhận {1}% thu nhập của họ trọn đời!"

msgid "Everyone can use the shortest way to shorten links with {0}."
msgstr "Mọi người đều có thể dùng cách ngắn nhất để rút gọn link với {0}."

msgid "Just copy the link below to address bar into your web browser, change last part to destination link and press ENTER. {0} will redirect you to your shortened link. Copy it wherever you want and get paid."
msgstr "Chỉ cần sao chép link dưới đây vào thanh địa chỉ trình duyệt, thay phần cuối bằng link đích và nhấn ENTER. {0} sẽ chuyển hướng đến link rút gọn của bạn. Sao chép và kiếm tiền."

msgid "If you want to use Quick Link with the interstitial advertising add the below code to the end of the URL"
msgstr "Nếu muốn dùng Quick Link với quảng cáo interstitial, thêm đoạn sau vào cuối URL"

msgid "If you want to use Quick Link with the banner advertising add the below code to the end of the URL"
msgstr "Nếu muốn dùng Quick Link với quảng cáo banner, thêm đoạn sau vào cuối URL"

msgid "If you want to use Quick Link without advertising add the below code to the end of the URL"
msgstr "Nếu muốn dùng Quick Link không quảng cáo, thêm đoạn sau vào cuối URL"

msgid "For developers {0} prepared <b>API</b> which returns responses in <b>JSON</b> or <b>TEXT</b> formats. "
msgstr "Cho nhà phát triển, {0} cung cấp <b>API</b> trả về phản hồi dạng <b>JSON</b> hoặc <b>TEXT</b>."

msgid "Currently there is one method which can be used to shorten links on behalf of your account."
msgstr "Hiện có một phương thức để rút gọn link thay mặt tài khoản của bạn."

msgid "All you have to do is to send a <b>GET</b> request with your API token and URL Like the following:"
msgstr "Bạn chỉ cần gửi yêu cầu <b>GET</b> với API token và URL như sau:"

msgid "You will get a JSON reposnse like the following"
msgstr "Bạn sẽ nhận phản hồi JSON như sau"

msgid "If you want a TEXT reposnse just add <b>&format=text</b> at the end of your request as the below example. This will return just the short link. Note that if an error occurs, it will not output anything."
msgstr "Nếu muốn phản hồi TEXT, thêm <b>&format=text</b> vào cuối yêu cầu như ví dụ dưới. Sẽ chỉ trả về link ngắn. Lưu ý nếu có lỗi sẽ không xuất gì."

msgid "If you want to use developers API with the interstitial advertising add the below code to the end of the URL"
msgstr "Nếu muốn dùng API với quảng cáo interstitial, thêm đoạn sau vào cuối URL"

msgid "If you want to use developers API with the banner advertising add the below code to the end of the URL"
msgstr "Nếu muốn dùng API với quảng cáo banner, thêm đoạn sau vào cuối URL"

msgid "If you want to use developers API without advertising add the below code to the end of the URL"
msgstr "Nếu muốn dùng API không quảng cáo, thêm đoạn sau vào cuối URL"

msgid "api & url are required fields and the other fields like alias, format & type are optional."
msgstr "api và url là bắt buộc, các trường khác như alias, format và type là tùy chọn."

msgid "That's it :)"
msgstr "Chỉ vậy thôi :)"

